# ── OS-APOW Environment Configuration ───────────────────────────
# Copy this file to `.env` and fill in the values.
# NEVER commit the `.env` file to version control.

# ── API ─────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# ── Security ────────────────────────────────────────────────────
# GitHub App webhook secret (from GitHub App settings)
WEBHOOK_SECRET=change-me-in-production

# ── GitHub ──────────────────────────────────────────────────────
# GitHub personal access token or App installation token
GITHUB_TOKEN=
GITHUB_ORG=
GITHUB_REPO=

# ── Sentinel ────────────────────────────────────────────────────
# Unique identifier for this Sentinel instance (auto-generated if empty)
SENTINEL_ID=
# Polling interval in seconds
SENTINEL_POLL_INTERVAL=60
# Task timeout in minutes before reconciliation
SENTINEL_TASK_TIMEOUT_MINUTES=120

# ── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── PostgreSQL ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://osapow:osapow@localhost:5432/osapow
POSTGRES_USER=osapow
POSTGRES_PASSWORD=osapow
POSTGRES_DB=osapow

# ── Shell Bridge ────────────────────────────────────────────────
SHELL_BRIDGE_PATH=./scripts/devcontainer-opencode.sh
