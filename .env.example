# OS-APOW Environment Configuration
# Copy this file to .env and fill in the values
# NEVER commit the .env file to version control

# GitHub Personal Access Token with repo, issues, and PR permissions
GITHUB_TOKEN=ghp_your_github_token_here

# GitHub App Webhook Secret (configured in GitHub App settings)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Target GitHub repository in org/repo format
GITHUB_REPOSITORY=your-org/your-repo

# LLM API Key for the AI worker (e.g., ZhipuAI, OpenAI)
LLM_API_KEY=your_llm_api_key_here

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
